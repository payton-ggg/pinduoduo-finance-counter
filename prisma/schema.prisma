datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

model Product {
  id        String   @id @default(uuid())
  name      String
  images    String[] // массив ссылок на фото
  olxUrl    String?
  pinduoduoUrl String?
  priceCNY  Float   @map("priceUAH")
  shippingUA Float?
  managementUAH Float?
  priceInUA Float?
  netPrice  Float?
  rateCNY   Float?
  rateUSD   Float?
  shippingType String?
  customShippingRate Float?

  workModalWindowIOS Boolean @default(false)
  soundReducer       Boolean @default(false)
  sensesOfEar        Boolean @default(false)
  wirelessCharger    Boolean @default(false)
  gyroscope          Boolean @default(false)

  weight    Float? 
  microphoneQuality Int?
  sellsCount Int?
  purchasedCount Int? @default(0)
  chip      String?
  equipment String?
  archive   Int? // null = not archived, any value = archived

  folderId  String?
  folder    Folder?   @relation(fields: [folderId], references: [id])

  expenses  Expense[]
  incomes   Income[]
  createdAt DateTime @default(now())
}


model Folder {
  id        String    @id @default(uuid())
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  products  Product[]
}

model Expense {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  amount    Float
  type      String
  createdAt DateTime @default(now())
}

model Income {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  amount    Float
  createdAt DateTime @default(now())
}

